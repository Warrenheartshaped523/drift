# Maintainer: phlx0 <https://github.com/phlx0>
pkgname=drift
pkgver=0.6.1
pkgrel=1
pkgdesc="Terminal screensaver and idle visualizer with animated scenes"
arch=('x86_64' 'aarch64')
url="https://github.com/phlx0/drift"
license=('MIT')
makedepends=('go')
provides=('drift')
conflicts=('drift-bin' 'drift-git')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/phlx0/drift/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    export CGO_ENABLED=0
    export GOPATH="${srcdir}/go"
    go build -trimpath \
        -ldflags "-s -w \
            -X main.version=${pkgver} \
            -X main.commit=v${pkgver} \
            -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        -o drift .
}

package() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    install -Dm755 drift "${pkgdir}/usr/bin/drift"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
